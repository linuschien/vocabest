@startuml user-vocabest-core-api-dynamic-targetlevel-selection
!pragma layout smetana
skinparam packageStyle rectangle
skinparam defaultFontName Inter

actor Learner as Actor

box "vocabest-core-api" #LightCyan
  participant "UserRestController" as RestAdapter <<Primary Adapter>>
  participant "UserRepository" as RepoAdapter <<Secondary Adapter>>
end box

Actor -> RestAdapter : updateUser(id, req)
activate RestAdapter

note right of RestAdapter
  TargetLevel updated from request
end note

RestAdapter -> RepoAdapter : findById(id)
activate RepoAdapter
RepoAdapter --> RestAdapter : Optional<User>
deactivate RepoAdapter

RestAdapter -> RepoAdapter : save(entity)
activate RepoAdapter
RepoAdapter --> RestAdapter : User
deactivate RepoAdapter

RestAdapter --> Actor : ResponseEntity<UserResponse>
deactivate RestAdapter

@enduml

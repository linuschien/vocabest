@startuml user-vocabest-core-api-unlimited-practice-and-positive-reinforcement
!pragma layout smetana
skinparam packageStyle rectangle
skinparam defaultFontName Inter

actor Learner as Actor

box "vocabest-core-api" #LightCyan
  participant "DailyProgressRestController" as RestAdapter <<Primary Adapter>>
  participant "DailyProgressRepository" as RepoAdapter <<Secondary Adapter>>
end box

Actor -> RestAdapter : updateDailyProgress(id, req)
activate RestAdapter

RestAdapter -> RepoAdapter : findById(id)
activate RepoAdapter
RepoAdapter --> RestAdapter : Optional<DailyProgress>
deactivate RepoAdapter

RestAdapter -> RepoAdapter : save(entity)
activate RepoAdapter
RepoAdapter --> RestAdapter : DailyProgress
deactivate RepoAdapter

RestAdapter --> Actor : ResponseEntity<DailyProgressResponse>
deactivate RestAdapter

@enduml

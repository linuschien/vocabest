@startuml user-vocabest-core-api-rendering-contextual-cloze-questions
!pragma layout smetana
skinparam packageStyle rectangle
skinparam defaultFontName Inter

actor Learner as Actor

box "vocabest-core-api" #LightCyan
  participant "QuizQuestionRestController" as RestAdapter <<Primary Adapter>>
  participant "QuizQuestionRepository" as RepoAdapter <<Secondary Adapter>>
end box

Actor -> RestAdapter : getQuizQuestionById(id)
activate RestAdapter

RestAdapter -> RepoAdapter : findById(id)
activate RepoAdapter
RepoAdapter --> RestAdapter : Optional<QuizQuestion>
deactivate RepoAdapter

RestAdapter --> Actor : ResponseEntity<QuizQuestionResponse>
deactivate RestAdapter

@enduml

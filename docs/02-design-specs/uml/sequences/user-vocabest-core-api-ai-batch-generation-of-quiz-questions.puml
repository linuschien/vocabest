@startuml user-vocabest-core-api-ai-batch-generation-of-quiz-questions

!pragma layout smetana
skinparam defaultFontName Inter
skinparam sequenceMessageAlign center

actor "System / Admin" as Admin
participant "QuizQuestionRestController" as RestController <<PrimaryAdapter>>
participant "QuizQuestionCommandService" as CommandService <<DomainService>>
participant "VocabularyWordRepository" as VocabRepository <<SecondaryAdapter>>
participant "QuizQuestionRepository" as QuizRepository <<SecondaryAdapter>>

Admin -> RestController : generateBatch(req: QuizQuestionActionRequest)
activate RestController

RestController -> CommandService : generateBatch(req)
activate CommandService

note right of CommandService
  根據 req.maxWordsToProcess 與 req.targetLevel 
  準備單字種子
end note

CommandService -> VocabRepository : findByExample(example: Example<VocabularyWord>)
activate VocabRepository
VocabRepository --> CommandService : List<VocabularyWord>
deactivate VocabRepository

note right of CommandService
  呼叫 AI 批次生成測驗題目
  驗證格式 (情境句、中譯、誘答項)
  並確保符合文法狀態與考頻數量
end note

group Loop [For each generated QuizQuestion]
  CommandService -> QuizRepository : save(entity: QuizQuestion)
  activate QuizRepository
  QuizRepository --> CommandService : QuizQuestion
  deactivate QuizRepository
end

CommandService --> RestController : OperationStatus
deactivate CommandService

RestController --> Admin : ResponseEntity<OperationStatus>
deactivate RestController

@enduml

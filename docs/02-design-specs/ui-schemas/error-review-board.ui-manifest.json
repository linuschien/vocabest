{
  "ui_id": "error-review-board",
  "domain_module": "UserAndLearningProgress",
  "root_element": {
    "id": "error-review-page",
    "abstract_type": "Container",
    "semantic_variant": "page",
    "children": [
      {
        "id": "error-review-header",
        "abstract_type": "Section",
        "semantic_variant": "summary-section",
        "children": [
          {
            "id": "error-review-title",

{
  "ui_id": "data-pipeline-admin",
  "domain_module": "Core",
  "root_element": {
    "id": "data-pipeline-container",
    "abstract_type": "Container",
    "semantic_variant": "page",
    "label": "Data Pipeline Admin",
    "children": [
      {
        "id": "admin-header",
        "abstract_type": "Heading",
        "label": "Data Pipeline Administration"
      },
      {
        "id": "admin-actions",
        "abstract_type": "Stack",
        "semantic_variant": "action-bar",
        "label": "Data Pipeline Actions",
        "children": [
          {
            "id": "trigger-open-import",
            "abstract_type": "Trigger",
            "semantic_variant": "primary",
            "label": "Import Vocabulary",
            "behavior_ref": "nielsen:visibility",
            "interactions": [
              {
                "on_event": "on_click",
                "target_id": "import-modal",
                "behavior_ref": "nielsen:visibility"
              }
            ]
          },
          {
            "id": "trigger-open-generate",
            "abstract_type": "Trigger",
            "semantic_variant": "secondary",
            "label": "Batch Generate Quizzes",
            "behavior_ref": "nielsen:visibility",
            "interactions": [
              {
                "on_event": "on_click",
                "target_id": "generate-modal",
                "behavior_ref": "nielsen:visibility"
              }
            ]
          }
        ]
      },
      {
        "id": "import-modal",
        "abstract_type": "Overlay",
        "semantic_variant": "modal",
        "label": "Import Official Vocabulary",
        "children": [
          {
            "id": "import-file-field",
            "abstract_type": "Field",
            "semantic_variant": "text",
            "label": "Vocabulary File",
            "behavior_ref": "nielsen:control",
            "required": true
          },
          {
            "id": "import-submit-trigger",
            "abstract_type": "Trigger",
            "semantic_variant": "primary",
            "label": "Confirm Import",
            "data_ref": "importBulk",
            "behavior_ref": "Official Vocabulary Import and Normalization",
            "feedback": {
              "on_success": {
                "type": "toast",
                "message_key": "Import successfully queued"
              },
              "on_error": {
                "type": "dialog",
                "message_key": "Import failed"
              }
            }
          }
        ]
      },
      {
        "id": "generate-modal",
        "abstract_type": "Overlay",
        "semantic_variant": "modal",
        "label": "AI Batch Generation",
        "children": [
          {
            "id": "generate-max-words",
            "abstract_type": "Field",
            "semantic_variant": "number",
            "label": "Max Words To Process",
            "behavior_ref": "nielsen:control",
            "required": true,
            "checks": [
              {
                "type": "required",
                "message": "Max words to process is required"
              }
            ]
          },
          {
            "id": "generate-target-level",
            "abstract_type": "Selection",
            "semantic_variant": "dropdown",
            "label": "Target Level",
            "behavior_ref": "nielsen:control",
            "ux_hints": {
              "max_visible_options": 7
            }
          },
          {
            "id": "generate-submit-trigger",
            "abstract_type": "Trigger",
            "semantic_variant": "primary",
            "label": "Start Batch Generation",
            "data_ref": "generateBatch",
            "behavior_ref": "AI Batch Generation of Quiz Questions",
            "feedback": {
              "on_success": {
                "type": "toast",
                "message_key": "Batch generation successfully triggered"
              },
              "on_error": {
                "type": "dialog",
                "message_key": "Batch generation failed"
              }
            }
          }
        ]
      }
    ]
  }
}

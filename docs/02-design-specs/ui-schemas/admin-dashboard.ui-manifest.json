{
    "ui_id": "admin-dashboard",
    "domain_module": "Admin",
    "root_element": {
        "id": "admin-container",
        "abstract_type": "Container",
        "semantic_variant": "page",
        "label": "Admin Dashboard",
        "children": [
            {
                "id": "question-filter-section",
                "abstract_type": "Section",
                "semantic_variant": "summary-section",
                "label": "Question Filters",
                "children": [
                    {
                        "id": "question-filter-stack",
                        "abstract_type": "Stack",
                        "semantic_variant": "filter-bar",
                        "label": "Filters",
                        "children": [
                            {
                                "id": "question-search-field",
                                "abstract_type": "Field",
                                "semantic_variant": "search",
                                "label": "Search Question",
                                "behavior_ref": "US-05-02: 系統管理員全站資料存取權限"
                            },
                            {
                                "id": "question-difficulty-select",
                                "abstract_type": "Selection",
                                "semantic_variant": "dropdown",
                                "label": "Difficulty Level",
                                "behavior_ref": "US-05-02: 系統管理員全站資料存取權限",
                                "ux_hints": {
                                    "max_visible_options": 7
                                }
                            }
                        ]
                    }
                ]
            },
            {
                "id": "question-list-section",
                "abstract_type": "Section",
                "semantic_variant": "list-section",
                "label": "Global Question Bank",
                "children": [
                    {
                        "id": "question-actions-stack",
                        "abstract_type": "Stack",
                        "semantic_variant": "action-bar",
                        "label": "Actions",
                        "children": [
                            {
                                "id": "create-question-btn",
                                "abstract_type": "Trigger",
                                "semantic_variant": "primary",
                                "label": "Add Question",
                                "behavior_ref": "US-05-02: 系統管理員全站資料存取權限",
                                "interactions": [
                                    {
                                        "on_event": "on_click",
                                        "target_id": "create-question-modal",
                                        "behavior_ref": "nielsen:control"
                                    }
                                ]
                            },
                            {
                                "id": "delete-question-btn",
                                "abstract_type": "Trigger",
                                "semantic_variant": "destructive",
                                "label": "Delete Question",
                                "data_ref": "deleteQuizQuestion",
                                "behavior_ref": "US-05-02: 系統管理員全站資料存取權限",
                                "confirm_delete": {
                                    "keyword_label": "Please type CONFIRM to delete this question",
                                    "keyword_value": "CONFIRM"
                                },
                                "feedback": {
                                    "on_success": {
                                        "type": "toast",
                                        "message_key": "Question deleted"
                                    },
                                    "on_error": {
                                        "type": "dialog",
                                        "message_key": "Error deleting question"
                                    }
                                },
                                "interactions": [
                                    {
                                        "on_event": "on_click",
                                        "target_id": "confirm-delete-question-modal",
                                        "behavior_ref": "nielsen:error-prevention"
                                    }
                                ]
                            }
                        ]
                    },
                    {
                        "id": "global-question-table",
                        "abstract_type": "Table",
                        "semantic_variant": "data-table",
                        "label": "Questions",
                        "data_ref": "listQuizQuestions",
                        "columns": [
                            {
                                "field": "contextualCloze",
                                "label": "Contextual Cloze",
                                "sortable": false
                            },
                            {
                                "field": "difficultyLevel",
                                "label": "Difficulty Level",
                                "sortable": true,
                                "default_sort": "asc"
                            }
                        ]
                    }
                ]
            },
            {
                "id": "user-management-section",
                "abstract_type": "Section",
                "semantic_variant": "list-section",
                "label": "User Management",
                "children": [
                    {
                        "id": "user-table",
                        "abstract_type": "Table",
                        "semantic_variant": "data-table",
                        "label": "Users",
                        "data_ref": "listUsers",
                        "columns": [
                            {
                                "field": "email",
                                "label": "Email",
                                "sortable": true,
                                "default_sort": "asc"
                            },
                            {
                                "field": "role",
                                "label": "Role",
                                "sortable": true
                            },
                            {
                                "field": "learningStreak",
                                "label": "Learning Streak",
                                "sortable": true
                            }
                        ]
                    }
                ]
            },
            {
                "id": "create-question-modal",
                "abstract_type": "Overlay",
                "semantic_variant": "modal",
                "label": "Create Question",
                "children": [
                    {
                        "id": "submit-question-btn",
                        "abstract_type": "Trigger",
                        "semantic_variant": "primary",
                        "label": "Save",
                        "data_ref": "createQuizQuestion",
                        "behavior_ref": "US-05-02: 系統管理員全站資料存取權限",
                        "feedback": {
                            "on_success": {
                                "type": "toast",
                                "message_key": "Question created"
                            },
                            "on_error": {
                                "type": "dialog",
                                "message_key": "Validation failed"
                            }
                        }
                    }
                ]
            },
            {
                "id": "confirm-delete-question-modal",
                "abstract_type": "Overlay",
                "semantic_variant": "confirm-dialog",
                "label": "Confirm Deletion",
                "children": [
                    {
                        "id": "confirm-delete-btn",
                        "abstract_type": "Trigger",
                        "semantic_variant": "destructive",
                        "label": "Confirm",
                        "data_ref": "deleteQuizQuestion",
                        "behavior_ref": "US-05-02: 系統管理員全站資料存取權限",
                        "confirm_delete": {
                            "keyword_label": "Please type CONFIRM to delete",
                            "keyword_value": "CONFIRM"
                        },
                        "feedback": {
                            "on_success": {
                                "type": "toast",
                                "message_key": "Deleted"
                            },
                            "on_error": {
                                "type": "dialog",
                                "message_key": "Failed to delete"
                            }
                        }
                    }
                ]
            }
        ]
    }
}

{
    "ui_id": "quiz-board",
    "domain_module": "QuizQuestion",
    "root_element": {
        "id": "quiz-container",
        "abstract_type": "Container",
        "semantic_variant": "page",
        "label": "Quiz",
        "children": [
            {
                "id": "question-section",
                "abstract_type": "Section",
                "semantic_variant": "summary-section",
                "label": "Question",
                "children": [
                    {
                        "id": "chinese-translation",
                        "abstract_type": "Text",
                        "label": "Chinese Translation",
                        "data_ref": "getNextQuestion"
                    },
                    {
                        "id": "contextual-cloze",
                        "abstract_type": "Text",
                        "label": "Contextual Cloze",
                        "data_ref": "getNextQuestion"
                    }
                ]
            },
            {
                "id": "options-grid",
                "abstract_type": "Grid",
                "semantic_variant": "card-grid",
                "label": "Options",
                "data_ref": "getNextQuestion",
                "ux_hints": {
                    "principles": ["fitts-law", "hicks-law"],
                    "group_size_hint": 4
                },
                "children": [
                    {
                        "id": "option-trigger",
                        "abstract_type": "Trigger",
                        "semantic_variant": "secondary",
                        "label": "Option",
                        "data_ref": "submitAnswer",
                        "behavior_ref": "US-02-01: 情境克漏字渲染",
                        "feedback": {
                            "on_success": {
                                "type": "toast",
                                "message_key": "Answer submitted"
                            },
                            "on_error": {
                                "type": "dialog",
                                "message_key": "System error submitting answer"
                            }
                        },
                        "interactions": [
                            {
                                "on_event": "on_submit",
                                "target_id": "explanation-modal",
                                "behavior_ref": "US-03-01: 答錯時的深度解析與記憶法"
                            }
                        ]
                    }
                ]
            },
            {
                "id": "explanation-modal",
                "abstract_type": "Overlay",
                "semantic_variant": "modal",
                "label": "Explanation",
                "children": [
                    {
                        "id": "explanation-content",
                        "abstract_type": "Text",
                        "label": "Explanation Root/Mnemonic",
                        "data_ref": "submitAnswer"
                    },
                    {
                        "id": "next-question-btn",
                        "abstract_type": "Trigger",
                        "semantic_variant": "primary",
                        "label": "Next Question",
                        "behavior_ref": "US-03-01: 答錯時的深度解析與記憶法",
                        "interactions": [
                            {
                                "on_event": "on_click",
                                "target_id": "quiz-container",
                                "behavior_ref": "nielsen:control"
                            }
                        ]
                    }
                ]
            }
        ]
    }
}

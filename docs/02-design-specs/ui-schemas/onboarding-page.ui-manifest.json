{
    "ui_id": "onboarding-page",
    "domain_module": "User",
    "root_element": {
        "id": "onboarding-container",
        "abstract_type": "Container",
        "semantic_variant": "page",
        "label": "Welcome to Vocabest",
        "children": [
            {
                "id": "onboarding-form-section",
                "abstract_type": "Section",
                "semantic_variant": "form-section",
                "label": "Initial Setup",
                "ux_hints": {
                    "principles": ["millers-law"],
                    "group_size_hint": 3
                },
                "children": [
                    {
                        "id": "target-level-select",
                        "abstract_type": "Selection",
                        "semantic_variant": "dropdown",
                        "label": "Target Level",
                        "required": true,
                        "behavior_ref": "nielsen:flexibility",
                        "ux_hints": {
                            "max_visible_options": 7
                        }
                    },
                    {
                        "id": "daily-target-select",
                        "abstract_type": "Selection",
                        "semantic_variant": "dropdown",
                        "label": "Daily Target Questions",
                        "required": true,
                        "behavior_ref": "nielsen:flexibility",
                        "ux_hints": {
                            "max_visible_options": 5
                        }
                    },
                    {
                        "id": "start-onboarding-btn",
                        "abstract_type": "Trigger",
                        "semantic_variant": "primary",
                        "label": "Start Learning",
                        "data_ref": "onboardUser",
                        "behavior_ref": "US-00-01: First Login & Onboarding",
                        "ux_hints": {
                            "principles": ["fitts-law", "visual-hierarchy:size"],
                            "primary_action_placement": "top-left"
                        },
                        "feedback": {
                            "on_success": {
                                "type": "toast",
                                "message_key": "Setup complete"
                            },
                            "on_error": {
                                "type": "dialog",
                                "message_key": "Failed to save settings"
                            }
                        },
                        "interactions": [
                            {
                                "on_event": "on_submit",
                                "target_id": "onboarding-form-section",
                                "behavior_ref": "nielsen:feedback"
                            }
                        ]
                    }
                ]
            }
        ]
    }
}

{
  "ui_id": "onboarding-page",
  "domain_module": "UserAndLearningProgress",
  "root_element": {
    "id": "onboarding-container",
    "abstract_type": "Container",
    "semantic_variant": "page",
    "children": [
      {
        "id": "target-level-form-section",
        "abstract_type": "Section",
        "semantic_variant": "form-section",
        "children": [
          {
            "id": "onboarding-title",
            "abstract_type": "Heading",
            "label": "Welcome! Choose Your Target Level"
          },
          {
            "id": "target-level-selection",
            "abstract_type": "Selection",
            "semantic_variant": "radio",
            "label": "Target Level",
            "behavior_ref": "nielsen:control",
            "ux_hints": {
              "principles": [
                "hicks-law"
              ],
              "max_visible_options": 2
            }
          },
          {
            "id": "submit-target-level",
            "abstract_type": "Trigger",
            "semantic_variant": "primary",
            "label": "Start Learning",
            "data_ref": "updateUser",
            "behavior_ref": "nielsen:feedback",
            "feedback": {
              "on_success": {
                "type": "toast",
                "message_key": "Settings saved successfully"
              },
              "on_error": {
                "type": "dialog",
                "message_key": "Failed to save settings. Please try again."
              }
            },
            "ux_hints": {
              "primary_action_placement": "top-right"
            }
          }
        ]
      }
    ]
  }
}

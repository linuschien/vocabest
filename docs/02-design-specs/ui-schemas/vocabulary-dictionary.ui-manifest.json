{
    "ui_id": "vocabulary-dictionary",
    "domain_module": "WordBank",
    "root_element": {
        "id": "dictionary-container",
        "abstract_type": "Container",
        "semantic_variant": "page",
        "label": "Vocabulary Dictionary",
        "children": [
            {
                "id": "filter-section",
                "abstract_type": "Section",
                "semantic_variant": "summary-section",
                "label": "Search & Filters",
                "children": [
                    {
                        "id": "filter-stack",
                        "abstract_type": "Stack",
                        "semantic_variant": "filter-bar",
                        "label": "Filters",
                        "children": [
                            {
                                "id": "search-field",
                                "abstract_type": "Field",
                                "semantic_variant": "search",
                                "label": "Search Word",
                                "behavior_ref": "US-01-04: 單字總覽與檢索"
                            },
                            {
                                "id": "letter-select",
                                "abstract_type": "Selection",
                                "semantic_variant": "dropdown",
                                "label": "Starts With",
                                "behavior_ref": "US-01-04: 單字總覽與檢索",
                                "ux_hints": {
                                    "max_visible_options": 7
                                }
                            },
                            {
                                "id": "difficulty-select",
                                "abstract_type": "Selection",
                                "semantic_variant": "dropdown",
                                "label": "Difficulty Level",
                                "behavior_ref": "US-01-04: 單字總覽與檢索",
                                "ux_hints": {
                                    "max_visible_options": 7
                                }
                            }
                        ]
                    }
                ]
            },
            {
                "id": "word-list-section",
                "abstract_type": "Section",
                "semantic_variant": "list-section",
                "label": "Word List",
                "children": [
                    {
                        "id": "admin-actions-stack",
                        "abstract_type": "Stack",
                        "semantic_variant": "action-bar",
                        "label": "Admin Actions",
                        "children": [
                            {
                                "id": "create-wordbank-btn",
                                "abstract_type": "Trigger",
                                "semantic_variant": "primary",
                                "label": "Add Word",
                                "behavior_ref": "US-05-02: 系統管理員全站資料存取權限",
                                "interactions": [
                                    {
                                        "on_event": "on_click",
                                        "target_id": "create-wordbank-modal",
                                        "behavior_ref": "nielsen:control"
                                    }
                                ]
                            },
                            {
                                "id": "drilldown-questions-btn",
                                "abstract_type": "Trigger",
                                "semantic_variant": "secondary",
                                "label": "Manage Questions (Drill-down)",
                                "behavior_ref": "US-05-02: 系統管理員全站資料存取權限"
                            },
                            {
                                "id": "delete-wordbank-btn",
                                "abstract_type": "Trigger",
                                "semantic_variant": "destructive",
                                "label": "Delete Word",
                                "data_ref": "deleteWordBank",
                                "behavior_ref": "US-05-02: 系統管理員全站資料存取權限",
                                "confirm_delete": {
                                    "keyword_label": "Please type the word to confirm deletion",
                                    "keyword_value": "{{wordBank.word}}"
                                },
                                "feedback": {
                                    "on_success": {
                                        "type": "toast",
                                        "message_key": "Word deleted"
                                    },
                                    "on_error": {
                                        "type": "dialog",
                                        "message_key": "Error deleting word"
                                    }
                                },
                                "interactions": [
                                    {
                                        "on_event": "on_click",
                                        "target_id": "confirm-delete-modal",
                                        "behavior_ref": "nielsen:error-prevention"
                                    }
                                ]
                            }
                        ]
                    },
                    {
                        "id": "word-table",
                        "abstract_type": "Table",
                        "semantic_variant": "data-table",
                        "label": "Words",
                        "data_ref": "listWordBanks",
                        "columns": [
                            {
                                "field": "word",
                                "label": "Word",
                                "sortable": true,
                                "default_sort": "asc"
                            },
                            {
                                "field": "partsOfSpeech",
                                "label": "Parts of Speech",
                                "sortable": false
                            },
                            {
                                "field": "chineseTranslation",
                                "label": "Chinese Translation",
                                "sortable": false
                            },
                            {
                                "field": "difficultyLevel",
                                "label": "Difficulty Level",
                                "sortable": true
                            }
                        ]
                    }
                ]
            },
            {
                "id": "create-wordbank-modal",
                "abstract_type": "Overlay",
                "semantic_variant": "modal",
                "label": "Create Word",
                "children": [
                    {
                        "id": "submit-wordbank-btn",
                        "abstract_type": "Trigger",
                        "semantic_variant": "primary",
                        "label": "Save",
                        "data_ref": "createWordBank",
                        "behavior_ref": "US-05-02: 系統管理員全站資料存取權限",
                        "feedback": {
                            "on_success": {
                                "type": "toast",
                                "message_key": "Word created"
                            },
                            "on_error": {
                                "type": "dialog",
                                "message_key": "Validation failed"
                            }
                        }
                    }
                ]
            },
            {
                "id": "confirm-delete-modal",
                "abstract_type": "Overlay",
                "semantic_variant": "confirm-dialog",
                "label": "Confirm Deletion",
                "children": [
                    {
                        "id": "confirm-delete-btn",
                        "abstract_type": "Trigger",
                        "semantic_variant": "destructive",
                        "label": "Confirm",
                        "data_ref": "deleteWordBank",
                        "behavior_ref": "US-05-02: 系統管理員全站資料存取權限",
                        "confirm_delete": {
                            "keyword_label": "Please type the word to confirm deletion",
                            "keyword_value": "{{wordBank.word}}"
                        },
                        "feedback": {
                            "on_success": {
                                "type": "toast",
                                "message_key": "Deleted"
                            },
                            "on_error": {
                                "type": "dialog",
                                "message_key": "Failed to delete"
                            }
                        }
                    }
                ]
            }
        ]
    }
}

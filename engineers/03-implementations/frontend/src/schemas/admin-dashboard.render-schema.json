{
  "root": "admin-container",
  "elements": {
    "admin-container": {
      "type": "Container:page",
      "props": {
        "id": "admin-container",
        "label": "Admin Dashboard"
      },
      "children": [
        "question-filter-section",
        "question-list-section",
        "user-management-section",
        "create-question-modal",
        "confirm-delete-question-modal"
      ]
    },
    "question-filter-section": {
      "type": "div",
      "props": {
        "id": "question-filter-section",
        "label": "Question Filters"
      },
      "children": [
        "question-filter-stack"
      ]
    },
    "question-filter-stack": {
      "type": "Stack",
      "props": {
        "id": "question-filter-stack",
        "label": "Filters"
      },
      "children": [
        "question-search-field",
        "question-difficulty-select"
      ]
    },
    "question-search-field": {
      "type": "Input",
      "props": {
        "id": "question-search-field",
        "label": "Search Question",
        "placeholder": "Select Search Question",
        "checks": null,
        "validateOn": null,
        "type": "text"
      },
      "children": []
    },
    "question-difficulty-select": {
      "type": "Select",
      "props": {
        "id": "question-difficulty-select",
        "label": "Difficulty Level",
        "placeholder": "Select Difficulty Level",
        "checks": null,
        "validateOn": null
      },
      "children": []
    },
    "question-list-section": {
      "type": "div",
      "props": {
        "id": "question-list-section",
        "label": "Global Question Bank"
      },
      "children": [
        "question-actions-stack",
        "global-question-table"
      ]
    },
    "question-actions-stack": {
      "type": "Stack",
      "props": {
        "id": "question-actions-stack",
        "label": "Actions"
      },
      "children": [
        "create-question-btn",
        "delete-question-btn"
      ]
    },
    "create-question-btn": {
      "type": "Button",
      "props": {
        "id": "create-question-btn",
        "label": "Add Question",
        "variant": "primary",
        "disabled": null
      },
      "children": [],
      "on": {
        "press": [
          {
            "action": "openModal",
            "params": {
              "id": "create-question-modal"
            }
          }
        ]
      }
    },
    "delete-question-btn": {
      "type": "Button",
      "props": {
        "id": "delete-question-btn",
        "label": "Delete Question",
        "variant": "danger",
        "disabled": null
      },
      "children": [],
      "on": {
        "press": [
          {
            "action": "openModal",
            "params": {
              "id": "confirm-delete-question-modal"
            }
          }
        ]
      }
    },
    "global-question-table": {
      "type": "DataTable",
      "props": {
        "id": "global-question-table",
        "label": "Questions",
        "columns": [
          {
            "field": "contextualCloze",
            "label": "Contextual Cloze",
            "sortable": false
          },
          {
            "field": "difficultyLevel",
            "label": "Difficulty Level",
            "sortable": true,
            "default_sort": "asc"
          }
        ],
        "data": {
          "$bindState": "/data/listQuizQuestions"
        }
      },
      "children": []
    },
    "user-management-section": {
      "type": "div",
      "props": {
        "id": "user-management-section",
        "label": "User Management"
      },
      "children": [
        "user-table"
      ]
    },
    "user-table": {
      "type": "DataTable",
      "props": {
        "id": "user-table",
        "label": "Users",
        "columns": [
          {
            "field": "email",
            "label": "Email",
            "sortable": true,
            "default_sort": "asc"
          },
          {
            "field": "role",
            "label": "Role",
            "sortable": true
          },
          {
            "field": "learningStreak",
            "label": "Learning Streak",
            "sortable": true
          }
        ],
        "data": {
          "$bindState": "/data/listUsers"
        }
      },
      "children": []
    },
    "create-question-modal": {
      "type": "Dialog",
      "props": {
        "id": "create-question-modal",
        "label": "Create Question",
        "title": "Create Question",
        "description": null,
        "openPath": "/modals/create-question-modal"
      },
      "children": [
        "submit-question-btn"
      ],
      "visible": {
        "$state": "/modals/create-question-modal"
      }
    },
    "submit-question-btn": {
      "type": "Button",
      "props": {
        "id": "submit-question-btn",
        "label": "Save",
        "variant": "primary",
        "disabled": null
      },
      "children": [],
      "on": {
        "press": [
          {
            "action": "executeBehavior",
            "params": {
              "ref": "US-05-02: 系統管理員全站資料存取權限"
            }
          }
        ]
      }
    },
    "confirm-delete-question-modal": {
      "type": "AlertDialog",
      "props": {
        "id": "confirm-delete-question-modal",
        "label": "Confirm Deletion",
        "title": "Confirm Deletion",
        "description": null,
        "openPath": "/modals/confirm-delete-question-modal"
      },
      "children": [
        "confirm-delete-btn"
      ],
      "visible": {
        "$state": "/modals/confirm-delete-question-modal"
      }
    },
    "confirm-delete-btn": {
      "type": "Button",
      "props": {
        "id": "confirm-delete-btn",
        "label": "Confirm",
        "variant": "danger",
        "disabled": null
      },
      "children": [],
      "on": {
        "press": [
          {
            "action": "executeBehavior",
            "params": {
              "ref": "US-05-02: 系統管理員全站資料存取權限"
            }
          }
        ]
      }
    }
  }
}
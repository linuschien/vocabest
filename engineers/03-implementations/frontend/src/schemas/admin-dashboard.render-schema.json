{
  "root": "admin-container",
  "elements": {
    "admin-container": {
      "type": "Container:page",
      "props": {
        "id": "admin-container",
        "label": "Admin Dashboard"
      },
      "children": [
        "user-management-section",
        "edit-user-modal"
      ]
    },
    "user-management-section": {
      "type": "div",
      "props": {
        "id": "user-management-section",
        "label": "User Management"
      },
      "children": [
        "user-table"
      ]
    },
    "user-table": {
      "type": "DataTable",
      "props": {
        "id": "user-table",
        "label": "Users",
        "columns": [
          {
            "field": "email",
            "label": "Email",
            "sortable": true,
            "default_sort": "asc"
          },
          {
            "field": "role",
            "label": "Role",
            "sortable": true
          },
          {
            "field": "learningStreak",
            "label": "Learning Streak",
            "sortable": true
          }
        ],
        "data": {
          "$bindState": "/data/listUsers"
        }
      },
      "children": []
    },
    "edit-user-modal": {
      "type": "Dialog",
      "props": {
        "id": "edit-user-modal",
        "label": "Edit User",
        "title": "Edit User Role",
        "description": null,
        "openPath": "/modals/edit-user-modal"
      },
      "children": [
        "user-role-select",
        "submit-user-btn"
      ],
      "visible": {
        "$state": "/modals/edit-user-modal"
      }
    },
    "user-role-select": {
      "type": "Select",
      "props": {
        "id": "user-role-select",
        "name": "role",
        "label": "Role",
        "options": [
          "USER",
          "ADMIN"
        ],
        "placeholder": "Select Role",
        "checks": null,
        "validateOn": null,
        "value": {
          "$bindState": "/form/user-role-select"
        }
      },
      "children": []
    },
    "submit-user-btn": {
      "type": "Button",
      "props": {
        "id": "submit-user-btn",
        "label": "Save",
        "variant": "primary",
        "disabled": null
      },
      "children": [],
      "on": {
        "press": [
          {
            "action": "executeBehavior",
            "params": {
              "ref": "updateUserRole",
              "payload": {
                "id": {
                  "$state": "/data/activeUserId"
                },
                "role": {
                  "$state": "/form/user-role-select"
                }
              }
            }
          }
        ]
      }
    }
  }
}

{
  "root": "dashboard-container",
  "elements": {
    "dashboard-container": {
      "type": "Container:page",
      "props": {
        "id": "dashboard-container",
        "label": "Learning Dashboard"
      },
      "children": [
        "global-header-section",
        "progress-section",
        "quick-start-section",
        "avatar-dropdown-modal",
        "onboarding-modal"
      ]
    },
    "global-header-section": {
      "type": "div",
      "props": {
        "id": "global-header-section",
        "label": "Header"
      },
      "children": [
        "avatar-dropdown-btn"
      ]
    },
    "avatar-dropdown-btn": {
      "type": "Button",
      "props": {
        "id": "avatar-dropdown-btn",
        "label": "User Menu",
        "variant": "secondary",
        "disabled": null
      },
      "children": [],
      "on": {
        "press": [
          {
            "action": "openModal",
            "params": {
              "id": "avatar-dropdown-modal"
            }
          }
        ]
      }
    },
    "progress-section": {
      "type": "div",
      "props": {
        "id": "progress-section",
        "label": "Today's Progress"
      },
      "children": [
        "progress-grid"
      ]
    },
    "progress-grid": {
      "type": "Grid",
      "props": {
        "id": "progress-grid",
        "label": "Key Metrics"
      },
      "children": [
        "questions-answered-metric",
        "learning-streak-metric"
      ]
    },
    "questions-answered-metric": {
      "type": "MetricCard",
      "props": {
        "id": "questions-answered-metric",
        "label": "Questions Answered"
      },
      "children": []
    },
    "learning-streak-metric": {
      "type": "MetricCard",
      "props": {
        "id": "learning-streak-metric",
        "label": "Learning Streak"
      },
      "children": []
    },
    "quick-start-section": {
      "type": "div",
      "props": {
        "id": "quick-start-section",
        "label": "Quick Start"
      },
      "children": [
        "quick-start-stack"
      ]
    },
    "quick-start-stack": {
      "type": "Stack",
      "props": {
        "id": "quick-start-stack",
        "label": "Actions"
      },
      "children": [
        "start-daily-task-btn",
        "error-review-btn",
        "nav-dictionary-btn"
      ]
    },
    "start-daily-task-btn": {
      "type": "Button",
      "props": {
        "id": "start-daily-task-btn",
        "label": "Start Today's Task",
        "variant": "primary",
        "disabled": null
      },
      "children": [],
      "on": {
        "press": [
          {
            "action": "navigate",
            "params": {
              "path": "/quiz-board"
            }
          }
        ]
      }
    },
    "error-review-btn": {
      "type": "Button",
      "props": {
        "id": "error-review-btn",
        "label": "Review Errors",
        "variant": "secondary",
        "disabled": null
      },
      "children": [],
      "on": {
        "press": [
          {
            "action": "navigate",
            "params": {
              "path": "/error-review-board"
            }
          }
        ]
      }
    },
    "nav-dictionary-btn": {
      "type": "Button",
      "props": {
        "id": "nav-dictionary-btn",
        "label": "Vocabulary Dictionary",
        "variant": "secondary",
        "disabled": null
      },
      "children": [],
      "on": {
        "press": [
          {
            "action": "navigate",
            "params": {
              "path": "/vocabulary-dictionary"
            }
          }
        ]
      }
    },
    "avatar-dropdown-modal": {
      "type": "Dialog",
      "props": {
        "id": "avatar-dropdown-modal",
        "label": "User Menu",
        "title": "User Menu",
        "description": null,
        "openPath": "/modals/avatar-dropdown-modal"
      },
      "children": [
        "nav-settings-btn",
        "nav-admin-btn"
      ],
      "visible": {
        "$state": "/modals/avatar-dropdown-modal"
      }
    },
    "nav-settings-btn": {
      "type": "Button",
      "props": {
        "id": "nav-settings-btn",
        "label": "Personal Settings",
        "variant": "secondary",
        "disabled": null
      },
      "children": [],
      "on": {
        "press": [
          {
            "action": "navigate",
            "params": {
              "path": "/onboarding"
            }
          }
        ]
      }
    },
    "nav-admin-btn": {
      "type": "Button",
      "props": {
        "id": "nav-admin-btn",
        "label": "Admin Dashboard",
        "variant": "secondary",
        "disabled": null
      },
      "children": [],
      "on": {
        "press": [
          {
            "action": "navigate",
            "params": {
              "path": "/admin-dashboard"
            }
          }
        ]
      }
    },
    "onboarding-modal": {
      "type": "Dialog",
      "props": {
        "id": "onboarding-modal",
        "label": "Welcome to Vocabest",
        "title": "Welcome to Vocabest",
        "description": "Please set your learning goals below.",
        "openPath": "/modals/onboarding-modal"
      },
      "children": [
        "welcome-message",
        "target-level-select",
        "daily-target-questions-select",
        "start-onboarding-btn"
      ],
      "visible": {
        "$state": "/modals/onboarding-modal"
      }
    },
    "welcome-message": {
      "type": "div",
      "props": {
        "className": "text-lg mb-4 text-center font-medium flex justify-center gap-1"
      },
      "children": [
        "welcome-text1",
        "welcome-text2",
        "welcome-text3"
      ]
    },
    "welcome-text1": {
      "type": "span",
      "props": {
        "children": "Welcome,"
      },
      "children": []
    },
    "welcome-text2": {
      "type": "span",
      "props": {
        "children": {
          "$state": "/data/user/email"
        },
        "className": "text-primary"
      },
      "children": []
    },
    "welcome-text3": {
      "type": "span",
      "props": {
        "children": "!"
      },
      "children": []
    },
    "target-level-select": {
      "type": "Select",
      "props": {
        "id": "target-level-select",
        "name": "targetLevel",
        "label": "Target Level",
        "required": true,
        "placeholder": "Select Target Level",
        "options": [
          "國中2000單字",
          "高中7000單字"
        ],
        "checks": null,
        "validateOn": null,
        "value": {
          "$bindState": "/form/target-level-select"
        }
      },
      "children": []
    },
    "daily-target-questions-select": {
      "type": "Select",
      "props": {
        "id": "daily-target-questions-select",
        "name": "dailyTargetQuestions",
        "label": "Daily Target Questions",
        "required": true,
        "placeholder": "Select Daily Target Questions",
        "options": [
          "10",
          "20",
          "50",
          "100"
        ],
        "checks": null,
        "validateOn": null,
        "value": {
          "$bindState": "/form/daily-target-questions-select"
        }
      },
      "children": []
    },
    "start-onboarding-btn": {
      "type": "Button",
      "props": {
        "id": "start-onboarding-btn",
        "label": "Start Learning",
        "variant": "primary",
        "disabled": null
      },
      "children": [],
      "on": {
        "press": [
          {
            "action": "executeBehavior",
            "params": {
              "ref": "onboardUser",
              "payload": {
                "targetLevel": {
                  "$state": "/form/target-level-select"
                },
                "dailyTargetQuestions": {
                  "$state": "/form/daily-target-questions-select"
                }
              }
            }
          }
        ]
      }
    }
  }
}
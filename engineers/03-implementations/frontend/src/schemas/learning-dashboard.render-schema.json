{
  "root": "dashboard-container",
  "elements": {
    "dashboard-container": {
      "type": "Container:page",
      "props": {
        "id": "dashboard-container",
        "label": "Learning Dashboard"
      },
      "children": [
        "top-cards-grid"
      ]
    },
    "top-cards-grid": {
      "type": "Grid",
      "props": {
        "id": "top-cards-grid",
        "columns": 2,
        "gap": "md",
        "className": "w-full"
      },
      "children": [
        "progress-section",
        "quick-start-section"
      ]
    },

    "progress-section": {
      "type": "Card",
      "props": {
        "id": "progress-section",
        "title": "Today's Progress"
      },
      "children": [
        "progress-grid"
      ]
    },
    "progress-grid": {
      "type": "Grid",
      "props": {
        "id": "progress-grid",
        "label": "Key Metrics"
      },
      "children": [
        "questions-answered-metric",
        "learning-streak-metric"
      ]
    },
    "questions-answered-metric": {
      "type": "MetricCard",
      "props": {
        "id": "questions-answered-metric",
        "label": "Questions Answered",
        "value": { "$state": "/data/todayProgress/answeredQuestions" }
      },
      "children": []
    },
    "learning-streak-metric": {
      "type": "MetricCard",
      "props": {
        "id": "learning-streak-metric",
        "label": "Learning Streak",
        "value": { "$state": "/data/user/learningStreak" }
      },
      "children": []
    },
    "quick-start-section": {
      "type": "Card",
      "props": {
        "id": "quick-start-section",
        "title": "Quick Start"
      },
      "children": [
        "quick-start-grid"
      ]
    },
    "quick-start-grid": {
      "type": "Grid",
      "props": {
        "id": "quick-start-grid",
        "columns": 2,
        "gap": "md",
        "className": "w-full"
      },
      "children": [
        "start-daily-task-btn",
        "error-review-btn",
        "nav-dictionary-btn"
      ]
    },
    "start-daily-task-btn": {
      "type": "Button",
      "props": {
        "id": "start-daily-task-btn",
        "label": "Start Today's Task",
        "variant": "outline",
        "className": "h-24 flex flex-col items-center justify-center text-base font-semibold shadow-sm col-span-2",
        "disabled": null
      },
      "children": [],
      "on": {
        "press": [
          {
            "action": "navigate",
            "params": {
              "path": "/quiz-board"
            }
          }
        ]
      }
    },
    "error-review-btn": {
      "type": "Button",
      "props": {
        "id": "error-review-btn",
        "label": "Review Errors",
        "variant": "outline",
        "className": "h-20 flex flex-col items-center justify-center shadow-sm",
        "disabled": null
      },
      "children": [],
      "on": {
        "press": [
          {
            "action": "navigate",
            "params": {
              "path": "/error-review-board"
            }
          }
        ]
      }
    },
    "nav-dictionary-btn": {
      "type": "Button",
      "props": {
        "id": "nav-dictionary-btn",
        "label": "Vocabulary Dictionary",
        "variant": "outline",
        "className": "h-20 flex flex-col items-center justify-center shadow-sm",
        "disabled": null
      },
      "children": [],
      "on": {
        "press": [
          {
            "action": "navigate",
            "params": {
              "path": "/vocabulary-dictionary"
            }
          }
        ]
      }
    }
  }
}
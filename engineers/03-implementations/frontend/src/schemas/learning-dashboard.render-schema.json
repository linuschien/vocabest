{
  "root": "dashboard-container",
  "elements": {
    "dashboard-container": {
      "type": "Container:page",
      "props": {
        "id": "dashboard-container",
        "label": "Learning Dashboard"
      },
      "children": [
        "top-cards-grid"
      ]
    },
    "top-cards-grid": {
      "type": "Grid",
      "props": {
        "id": "top-cards-grid",
        "columns": 2,
        "gap": "md",
        "className": "w-full"
      },
      "children": [
        "progress-section",
        "quick-start-section"
      ]
    },

    "progress-section": {
      "type": "Card",
      "props": {
        "id": "progress-section",
        "title": "戰績面板"
      },
      "children": [
        "progress-grid"
      ]
    },
    "progress-grid": {
      "type": "Grid",
      "props": {
        "id": "progress-grid",
        "label": "Key Metrics"
      },
      "children": [
        "questions-answered-metric",
        "learning-streak-metric"
      ]
    },
    "questions-answered-metric": {
      "type": "MetricCard",
      "props": {
        "id": "questions-answered-metric",
        "label": "今日進度",
        "variant": "progress",
        "current": { "$state": "/data/todayProgress/answeredQuestions" },
        "goal": { "$state": "/data/todayProgress/targetQuestions" },
        "best": { "$state": "/data/user/maxDailyQuestions" }
      },
      "children": []
    },
    "learning-streak-metric": {
      "type": "MetricCard",
      "props": {
        "id": "learning-streak-metric",
        "label": "目前連續挑戰天數",
        "variant": "streak",
        "value": { "$state": "/data/user/learningStreak" },
        "best": { "$state": "/data/user/maxLearningStreak" }
      },
      "children": []
    },
    "quick-start-section": {
      "type": "Card",
      "props": {
        "id": "quick-start-section",
        "title": "出發探險"
      },
      "children": [
        "main-quest-title",
        "main-quest-grid",
        "side-quest-title",
        "side-quest-grid"
      ]
    },
    "main-quest-title": {
      "type": "Text",
      "props": { 
        "text": "主線任務",
        "className": "text-sm font-bold text-muted-foreground mb-3 block" 
      }
    },
    "main-quest-grid": {
      "type": "Grid",
      "props": {
        "id": "main-quest-grid",
        "columns": 2,
        "gap": "md",
        "className": "w-full"
      },
      "children": [
        "start-daily-task-btn",
        "error-review-btn",
        "nav-dictionary-btn",
        "nav-critical-mission-log-btn"
      ]
    },
    "side-quest-title": {
      "type": "Text",
      "props": { 
        "text": "支線任務",
        "className": "text-sm font-bold text-muted-foreground mt-6 mb-3 block" 
      }
    },
    "side-quest-grid": {
      "type": "Grid",
      "props": {
        "id": "side-quest-grid",
        "columns": 2,
        "gap": "md",
        "className": "w-full"
      },
      "children": [
        "nav-wordle-btn",
        "nav-crossword-btn",
        "nav-memory-game-btn"
      ]
    },
    "start-daily-task-btn": {
      "type": "Button",
      "props": {
        "id": "start-daily-task-btn",
        "label": "⚔️ 開始今日任務",
        "variant": "outline",
        "disabled": null
      },
      "children": [],
      "on": {
        "press": [
          {
            "action": "navigate",
            "params": {
              "path": "/quiz-board"
            }
          }
        ]
      }
    },
    "error-review-btn": {
      "type": "ErrorReviewButton",
      "props": {
        "id": "error-review-btn",
        "count": { "$state": "/data/errorReviewCount" }
      },
      "children": [],
      "on": {
        "press": [
          {
            "action": "navigate",
            "params": {
              "path": "/error-review-board"
            }
          }
        ]
      }
    },
    "nav-dictionary-btn": {
      "type": "Button",
      "props": {
        "id": "nav-dictionary-btn",
        "label": "📜 單字卷軸",
        "variant": "outline",
        "disabled": null
      },
      "children": [],
      "on": {
        "press": [
          {
            "action": "navigate",
            "params": {
              "path": "/vocabulary-dictionary"
            }
          }
        ]
      }
    },
    "nav-critical-mission-log-btn": {
      "type": "Button",
      "props": {
        "id": "nav-critical-mission-log-btn",
        "label": "📓 關鍵任務日誌",
        "variant": "outline",
        "disabled": null
      },
      "children": [],
      "on": {
        "press": [
          {
            "action": "navigate",
            "params": {
              "path": "/critical-mission-log"
            }
          }
        ]
      }
    },
    "nav-wordle-btn": {
      "type": "Button",
      "props": {
        "id": "nav-wordle-btn",
        "label": "🧩 Wordle 挑戰",
        "variant": "outline",
        "disabled": null
      },
      "children": [],
      "on": {
        "press": [
          {
            "action": "navigate",
            "params": {
              "path": "/wordle"
            }
          }
        ]
      }
    },
    "nav-crossword-btn": {
      "type": "Button",
      "props": {
        "id": "nav-crossword-btn",
        "label": "📝 填字遊戲",
        "variant": "outline",
        "disabled": null
      },
      "children": [],
      "on": {
        "press": [
          {
            "action": "navigate",
            "params": {
              "path": "/crossword"
            }
          }
        ]
      }
    },
    "nav-memory-game-btn": {
      "type": "Button",
      "props": {
        "id": "nav-memory-game-btn",
        "label": "🧠 翻牌對對碰",
        "variant": "outline",
        "disabled": null
      },
      "children": [],
      "on": {
        "press": [
          {
            "action": "navigate",
            "params": {
              "path": "/memory-game"
            }
          }
        ]
      }
    }
  }
}
{
  "root": "error-review-page-wrapper",
  "elements": {
    "error-review-page-wrapper": {
      "type": "Container:quiz-page",
      "props": { "id": "error-review-page-wrapper" },
      "children": ["error-review-card"]
    },
    "error-review-card": {
      "type": "Container:quiz-card",
      "props": { "id": "error-review-card" },
      "children": [
        "error-review-header",
        "question-section",
        "options-section",
        "explanation-modal"
      ]
    },
    "error-review-header": {
      "type": "Container:quiz-header",
      "props": { "id": "error-review-header" },
      "children": ["error-review-title"]
    },
    "error-review-title": {
      "type": "Text",
      "props": {
        "id": "error-review-title",
        "className": "text-lg font-semibold text-destructive",
        "text": "🛡️ 弱點特訓"
      },
      "children": []
    },
    "question-section": {
      "type": "Container:question-block",
      "props": { "id": "question-section" },
      "children": ["chinese-translation", "contextual-cloze"]
    },
    "chinese-translation": {
      "type": "Text",
      "props": {
        "id": "chinese-translation",
        "className": "text-base text-muted-foreground leading-relaxed",
        "text": { "$state": "/data/activeQuestion/chineseTranslation" }
      },
      "children": []
    },
    "contextual-cloze": {
      "type": "Text",
      "props": {
        "id": "contextual-cloze",
        "className": "text-xl font-medium leading-relaxed tracking-wide",
        "text": { "$state": "/data/activeQuestion/contextualCloze" }
      },
      "children": []
    },
    "options-section": {
      "type": "Container:options-grid",
      "props": { "id": "options-section" },
      "children": ["option-0", "option-1", "option-2", "option-3"]
    },
    "option-0": {
      "type": "button",
      "props": {
        "id": "option-0",
        "disabled": { "$state": "/data/lastAnswerResult" },
        "label": { "$state": "/data/shuffledOptions/0" },
        "className": "kahoot-btn kahoot-btn-0"
      },
      "children": [],
      "on": {
        "press": [
          {
            "action": "executeBehavior",
            "params": {
              "ref": "submitAnswer",
              "payload": {
                "questionId": { "$state": "/data/activeQuestionId" },
                "selectedDistractor": { "$state": "/data/shuffledOptions/0" }
              }
            }
          }
        ]
      }
    },
    "option-1": {
      "type": "button",
      "props": {
        "id": "option-1",
        "disabled": { "$state": "/data/lastAnswerResult" },
        "label": { "$state": "/data/shuffledOptions/1" },
        "className": "kahoot-btn kahoot-btn-1"
      },
      "children": [],
      "on": {
        "press": [
          {
            "action": "executeBehavior",
            "params": {
              "ref": "submitAnswer",
              "payload": {
                "questionId": { "$state": "/data/activeQuestionId" },
                "selectedDistractor": { "$state": "/data/shuffledOptions/1" }
              }
            }
          }
        ]
      }
    },
    "option-2": {
      "type": "button",
      "props": {
        "id": "option-2",
        "disabled": { "$state": "/data/lastAnswerResult" },
        "label": { "$state": "/data/shuffledOptions/2" },
        "className": "kahoot-btn kahoot-btn-2"
      },
      "children": [],
      "on": {
        "press": [
          {
            "action": "executeBehavior",
            "params": {
              "ref": "submitAnswer",
              "payload": {
                "questionId": { "$state": "/data/activeQuestionId" },
                "selectedDistractor": { "$state": "/data/shuffledOptions/2" }
              }
            }
          }
        ]
      }
    },
    "option-3": {
      "type": "button",
      "props": {
        "id": "option-3",
        "disabled": { "$state": "/data/lastAnswerResult" },
        "label": { "$state": "/data/shuffledOptions/3" },
        "className": "kahoot-btn kahoot-btn-3"
      },
      "children": [],
      "on": {
        "press": [
          {
            "action": "executeBehavior",
            "params": {
              "ref": "submitAnswer",
              "payload": {
                "questionId": { "$state": "/data/activeQuestionId" },
                "selectedDistractor": { "$state": "/data/shuffledOptions/3" }
              }
            }
          }
        ]
      }
    },
    "explanation-modal": {
      "type": "Dialog",
      "props": {
        "id": "explanation-modal",
        "label": "作答結果",
        "title": { "$state": "/data/lastAnswerResult/isCorrect" },
        "description": null,
        "openPath": "/modals/explanation-modal"
      },
      "children": [
        "result-badge",
        "correct-answer-text",
        "explanation-root-affix",
        "explanation-mnemonic",
        "next-question-btn"
      ],
      "visible": { "$state": "/modals/explanation-modal" }
    },
    "result-badge": {
      "type": "Text",
      "props": {
        "id": "result-badge",
        "className": "text-center text-2xl font-bold",
        "text": { "$state": "/data/lastAnswerResultLabel" }
      },
      "children": []
    },
    "correct-answer-text": {
      "type": "Text",
      "props": {
        "id": "correct-answer-text",
        "className": "text-center text-base text-muted-foreground",
        "text": { "$state": "/data/lastAnswerCorrectLabel" }
      },
      "children": []
    },
    "explanation-root-affix": {
      "type": "Text",
      "props": {
        "id": "explanation-root-affix",
        "className": "text-sm text-foreground",
        "text": { "$state": "/data/lastAnswerResult/explanationRootAffix" }
      },
      "children": []
    },
    "explanation-mnemonic": {
      "type": "Text",
      "props": {
        "id": "explanation-mnemonic",
        "className": "text-sm text-muted-foreground italic",
        "text": { "$state": "/data/lastAnswerResult/explanationMnemonic" }
      },
      "children": []
    },
    "next-question-btn": {
      "type": "Button",
      "props": {
        "id": "next-question-btn",
        "label": "下一題",
        "variant": "primary"
      },
      "children": [],
      "on": {
        "press": [
          {
            "action": "executeBehavior",
            "params": {
              "ref": "loadNextErrorQuestion"
            }
          }
        ]
      }
    }
  }
}

{
  "root": "user-management-container",
  "elements": {
    "user-management-container": {
      "type": "Container:page",
      "props": {
        "id": "user-management-container",
        "label": "User Management"
      },
      "children": [
        "user-management-section",
        "edit-user-modal"
      ]
    },
    "user-management-section": {
      "type": "div",
      "props": {
        "id": "user-management-section",
        "label": "User Management"
      },
      "children": [
        "user-table"
      ]
    },
    "user-table": {
      "type": "DataTable",
      "props": {
        "id": "user-table",
        "label": "Users",
        "columns": [
          { "field": "email", "label": "Email", "sortable": true, "default_sort": "asc" },
          { "field": "role", "label": "Role", "sortable": true },
          { "field": "targetLevel", "label": "Target Level", "sortable": true },
          { "field": "learningStreak", "label": "Learning Streak", "sortable": true },
          { "field": "maxLearningStreak", "label": "Max Streak", "sortable": true },
          { "field": "maxDailyQuestions", "label": "Max Daily Qs", "sortable": true },
          { "field": "dailyTargetQuestions", "label": "Target Qs", "sortable": true },
          { "field": "stats.totalQuestionsAnswered", "label": "Total Answered", "sortable": false },
          { "field": "stats.totalCorrectAnswers", "label": "Total Correct", "sortable": false },
          { "field": "stats.overallAccuracy", "label": "Accuracy (%)", "sortable": false }
        ],
        "data": {
          "$bindState": "/data/listUsers"
        }
      },
      "children": []
    },
    "edit-user-modal": {
      "type": "Dialog",
      "props": {
        "id": "edit-user-modal",
        "label": "Edit User",
        "title": "Edit User Role",
        "description": null,
        "openPath": "/modals/edit-user-modal"
      },
      "children": [
        "user-role-select",
        "submit-user-btn"
      ],
      "visible": {
        "$state": "/modals/edit-user-modal"
      }
    },
    "user-role-select": {
      "type": "Select",
      "props": {
        "id": "user-role-select",
        "name": "role",
        "label": "Role",
        "options": [
          "USER",
          "ADMIN"
        ],
        "placeholder": "Select Role",
        "checks": null,
        "validateOn": null,
        "value": {
          "$bindState": "/form/user-role-select"
        }
      },
      "children": []
    },
    "submit-user-btn": {
      "type": "Button",
      "props": {
        "id": "submit-user-btn",
        "label": "Save",
        "variant": "primary",
        "disabled": null
      },
      "children": [],
      "on": {
        "press": [
          {
            "action": "executeBehavior",
            "params": {
              "ref": "updateUserRole",
              "payload": {
                "id": {
                  "$state": "/data/activeUserId"
                },
                "role": {
                  "$state": "/form/user-role-select"
                }
              }
            }
          }
        ]
      }
    }
  }
}
